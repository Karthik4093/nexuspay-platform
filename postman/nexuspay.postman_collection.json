{
  "info": {
    "name": "NexusPay Platform API",
    "description": "Complete API collection for NexusPay Payment Orchestration Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_exporter_id": "nexuspay"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000/api/v1", "type": "string" },
    { "key": "accessToken", "value": "", "type": "string" },
    { "key": "refreshToken", "value": "", "type": "string" },
    { "key": "merchantId", "value": "", "type": "string" },
    { "key": "customerId", "value": "", "type": "string" },
    { "key": "paymentId", "value": "", "type": "string" }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{accessToken}}", "type": "string" }]
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"test@example.com\",\n  \"password\": \"Test@123456\",\n  \"role\": \"MERCHANT\"\n}"
            }
          }
        },
        {
          "name": "Login (Admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "  console.log('Tokens saved');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nexuspay.com\",\n  \"password\": \"Admin@123456\"\n}"
            }
          }
        },
        {
          "name": "Login (Merchant)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('accessToken', body.data.accessToken);",
                  "  pm.collectionVariables.set('refreshToken', body.data.refreshToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"billing@techcorp.com\",\n  \"password\": \"Merchant@123456\"\n}"
            }
          }
        },
        {
          "name": "Get Current User",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/auth/me"
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}"
            }
          }
        },
        {
          "name": "Change Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/change-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"currentPassword\": \"Admin@123456\",\n  \"newPassword\": \"NewAdmin@123456\"\n}"
            }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/forgot-password",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@nexuspay.com\"\n}"
            }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/auth/logout"
          }
        }
      ]
    },
    {
      "name": "Merchants",
      "item": [
        {
          "name": "List Merchants",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.data && body.data.data.length > 0) {",
                  "    pm.collectionVariables.set('merchantId', body.data.data[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/merchants?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "ACTIVE", "disabled": true },
                { "key": "search", "value": "", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Merchant",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/merchants/{{merchantId}}"
          }
        },
        {
          "name": "Create Merchant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/merchants",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"businessName\": \"Acme Corp\",\n  \"businessEmail\": \"payments@acme.com\",\n  \"businessPhone\": \"+15551234567\",\n  \"businessAddress\": \"123 Main St, San Francisco, CA 94105\",\n  \"country\": \"US\",\n  \"currency\": \"USD\",\n  \"category\": \"E_COMMERCE\",\n  \"userId\": \"<user-id>\"\n}"
            }
          }
        },
        {
          "name": "Suspend Merchant",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/merchants/{{merchantId}}/suspend"
          }
        },
        {
          "name": "Activate Merchant",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/merchants/{{merchantId}}/activate"
          }
        },
        {
          "name": "Rotate API Keys",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/merchants/{{merchantId}}/rotate-keys"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "List Payments",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.data && body.data.data.length > 0) {",
                  "    pm.collectionVariables.set('paymentId', body.data.data[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/payments?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" },
                { "key": "status", "value": "SUCCESS", "disabled": true },
                { "key": "startDate", "value": "2026-01-01", "disabled": true },
                { "key": "endDate", "value": "2026-12-31", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Create Payment",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.request.headers.add({",
                  "  key: 'X-Idempotency-Key',",
                  "  value: 'idk_' + Date.now() + '_' + Math.random().toString(36).substr(2, 9)",
                  "});"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "  const body = pm.response.json();",
                  "  pm.collectionVariables.set('paymentId', body.data.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-Idempotency-Key", "value": "unique-key-{{$randomUUID}}" }
            ],
            "url": "{{baseUrl}}/payments",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\",\n  \"amount\": 99.99,\n  \"currency\": \"USD\",\n  \"paymentMethod\": \"CREDIT_CARD\",\n  \"description\": \"Order #12345\",\n  \"metadata\": { \"orderId\": \"12345\" }\n}"
            }
          }
        },
        {
          "name": "Get Payment",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/{{paymentId}}"
          }
        },
        {
          "name": "Cancel Payment",
          "request": {
            "method": "POST",
            "url": "{{baseUrl}}/payments/{{paymentId}}/cancel"
          }
        },
        {
          "name": "Payment Stats",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/payments/stats"
          }
        }
      ]
    },
    {
      "name": "Customers",
      "item": [
        {
          "name": "List Customers",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  if (body.data && body.data.data && body.data.data.length > 0) {",
                  "    pm.collectionVariables.set('customerId', body.data.data[0].id);",
                  "  }",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/customers?page=1&limit=10",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "Get Customer",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/customers/{{customerId}}"
          }
        },
        {
          "name": "Create Customer",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/customers",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchantId\": \"{{merchantId}}\",\n  \"name\": \"Jane Doe\",\n  \"email\": \"jane.doe@example.com\",\n  \"phone\": \"+15559876543\",\n  \"country\": \"US\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Refunds",
      "item": [
        {
          "name": "List Refunds",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/refunds"
          }
        },
        {
          "name": "Create Refund",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/refunds",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"paymentId\": \"{{paymentId}}\",\n  \"amount\": 9.99,\n  \"reason\": \"Customer request\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Reports",
      "item": [
        {
          "name": "List Reports",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/reports"
          }
        },
        {
          "name": "Generate Report",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/reports",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"PAYMENT_SUMMARY\",\n  \"startDate\": \"2026-06-01\",\n  \"endDate\": \"2026-06-30\",\n  \"format\": \"JSON\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Audit",
      "item": [
        {
          "name": "List Audit Logs",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/audit?page=1&limit=20",
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "20" },
                { "key": "action", "value": "PAYMENT_CREATED", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Health",
      "item": [
        {
          "name": "API Health",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/health"
          }
        },
        {
          "name": "API Ready",
          "request": {
            "method": "GET",
            "url": "http://localhost:3000/ready"
          }
        },
        {
          "name": "Fraud Detection Health",
          "request": {
            "method": "GET",
            "url": "http://localhost:8001/health"
          }
        },
        {
          "name": "Currency Conversion Health",
          "request": {
            "method": "GET",
            "url": "http://localhost:8002/health"
          }
        },
        {
          "name": "Tax Calculation Health",
          "request": {
            "method": "GET",
            "url": "http://localhost:8003/health"
          }
        },
        {
          "name": "Notification Service Health",
          "request": {
            "method": "GET",
            "url": "http://localhost:8004/health"
          }
        }
      ]
    }
  ]
}
