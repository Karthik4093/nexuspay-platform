{
  "name": "nexuspay-api-gateway",
  "version": "1.0.0",
  "description": "NexusPay Payment Orchestration Platform - API Gateway",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint src --ext .ts --max-warnings 0",
    "lint:fix": "eslint src --ext .ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:seed": "tsx prisma/seeds/seed.ts",
    "db:reset": "prisma migrate reset --force && tsx prisma/seeds/seed.ts",
    "db:studio": "prisma studio",
    "docker:build": "docker build -t nexuspay-api .",
    "docker:run": "docker run -p 3000:3000 nexuspay-api"
  },
  "dependencies": {
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^3.0.0",
    "@fastify/cookie": "^9.3.1",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/auto-instrumentations-node": "^0.41.0",
    "@opentelemetry/exporter-jaeger": "^1.18.1",
    "@opentelemetry/exporter-prometheus": "^0.45.1",
    "@opentelemetry/instrumentation-fastify": "^0.36.1",
    "@opentelemetry/instrumentation-http": "^0.45.1",
    "@opentelemetry/instrumentation-pg": "^0.38.1",
    "@opentelemetry/instrumentation-ioredis": "^0.38.1",
    "@opentelemetry/instrumentation-amqplib": "^0.36.1",
    "@opentelemetry/sdk-node": "^0.45.1",
    "@opentelemetry/sdk-trace-base": "^1.18.1",
    "@opentelemetry/resources": "^1.18.1",
    "@opentelemetry/semantic-conventions": "^1.18.1",
    "@prisma/client": "^5.7.1",
    "amqplib": "^0.10.3",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.1.1",
    "fastify": "^4.25.2",
    "ioredis": "^5.3.2",
    "nanoid": "^3.3.7",
    "node-cron": "^3.0.3",
    "opossum": "^8.1.3",
    "p-retry": "^5.1.2",
    "pino": "^8.17.2",
    "pino-pretty": "^10.3.1",
    "prom-client": "^15.1.0",
    "uuid": "^9.0.1",
    "zod": "^3.22.4",
    "axios": "^1.6.5",
    "ms": "^2.1.3"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/ms": "^0.7.34",
    "@types/node": "^20.11.5",
    "@types/node-cron": "^3.0.11",
    "@types/opossum": "^8.1.4",
    "@types/uuid": "^9.0.7",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1",
    "@vitest/coverage-v8": "^1.2.1",
    "eslint": "^8.56.0",
    "prettier": "^3.2.4",
    "prisma": "^5.7.1",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
