# =============================================================================
# NexusPay Platform - Environment Variables
# Copy this file to .env and fill in the values
# =============================================================================

# Application
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1
SERVICE_NAME=nexuspay-api-gateway

# Database
DATABASE_URL=postgresql://nexuspay:nexuspay_secret@localhost:5432/nexuspay_db?schema=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://nexuspay:nexuspay_secret@localhost:5672
RABBITMQ_EXCHANGE=nexuspay.events
RABBITMQ_VHOST=/

# JWT
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Bcrypt
BCRYPT_ROUNDS=12

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# CORS
CORS_ORIGIN=http://localhost:8080

# Python Microservices
FRAUD_SERVICE_URL=http://localhost:8001
CURRENCY_SERVICE_URL=http://localhost:8002
TAX_SERVICE_URL=http://localhost:8003
NOTIFICATION_SERVICE_URL=http://localhost:8004
REPORT_SERVICE_URL=http://localhost:8005
ANALYTICS_SERVICE_URL=http://localhost:8006
RECOMMENDATION_SERVICE_URL=http://localhost:8007
INVENTORY_SERVICE_URL=http://localhost:8008
DOCUMENT_SERVICE_URL=http://localhost:8009
AI_SCORING_SERVICE_URL=http://localhost:8010

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# OpenTelemetry
OTEL_ENABLED=true
OTEL_SERVICE_NAME=nexuspay-api-gateway
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
JAEGER_ENDPOINT=http://localhost:14268/api/traces

# Prometheus
PROMETHEUS_PORT=9090
METRICS_PORT=9091

# Logging
LOG_LEVEL=info
LOG_PRETTY=false

# BullMQ
QUEUE_CONCURRENCY=5
QUEUE_ATTEMPTS=3

# Frontend
FRONTEND_URL=http://localhost:8080

# Idempotency
IDEMPOTENCY_KEY_TTL=86400

# Scheduler
RECONCILIATION_CRON=0 * * * *
MERCHANT_SUMMARY_CRON=0 */3 * * *
REPORT_GENERATION_CRON=0 0 * * *
AUDIT_CLEANUP_CRON=0 0 * * 0
ARCHIVAL_CRON=0 0 1 * *
